# Backend environment variables (set these where the API runs — e.g. the
# `primeconnect` Vercel project). Copy to .env for local dev.

# Core
MONGO_URI=mongodb://localhost:27017/primeconnect
JWT_SECRET=change-me-to-a-long-random-string
PORT=3000

# Website origin, used to build password-reset links in emails
FRONTEND_URL=https://primeconnect-frontend.vercel.app

# Email (password reset + support) via Resend's HTTPS API — works on Vercel,
# where SMTP is blocked. Get a key at https://resend.com. EMAIL_FROM must be a
# verified sender; onboarding@resend.dev works for testing to your own address.
RESEND_API_KEY=
EMAIL_FROM=PrimeConnect <onboarding@resend.dev>

# Where support reports are emailed
ADMIN_EMAIL=

# Payments (Paystack)
PAYSTACK_SECRET_KEY=
CLIENT_URL=https://primeconnect-frontend.vercel.app

# SMS / virtual numbers
GRIZZLY_API_KEY=
